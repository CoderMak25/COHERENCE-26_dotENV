# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/outreachos

# Redis (TCP) - required for Bull queue workers
# For Upstash, use the `rediss://...` URL from the Upstash console here.
REDIS_URL=redis://localhost:6379

# Upstash Redis (REST API) - used by app-level rate limiting/throttling
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI
OPENAI_API_KEY=sk-...

# Email (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...
EMAIL_FROM=outreach@yourdomain.com

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_USE_MOCK=true
